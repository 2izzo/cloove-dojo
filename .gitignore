# Node build artifacts
node_modules/
package-lock.json

# Eval run logs
*.log

# Older results dir (pre-.workspace convention)
results/

# Per-run deps inside .workspace (preserve code, drop deps)
.workspace/*/node_modules/
.workspace/*/package-lock.json

# Per-cloove mempalaces (Rung 1: write-only, dev-cloove)
.palaces/*/storage/
.palaces/*/content/wins/**/*.md
.palaces/*/content/scars/**/*.md
.palaces/*/content/general/**/*.md
.palaces/*/content/entities.json
