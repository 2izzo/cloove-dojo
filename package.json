{
  "name": "cloove-dojo",
  "version": "0.1.0",
  "description": "Eval harness for testing prompt x model x process combinations on coding katas",
  "type": "module",
  "scripts": {
    "kata": "bun run runner/run-kata.ts",
    "suite": "bun run runner/run-suite.ts",
    "score": "bun run scorer/score-run.ts",
    "compare": "bun run scorer/comparator.ts",
    "dev": "bun run frontend/server.ts",
    "test": "vitest",
    "test:features": "node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber.js tests/features --import \"tests/support/**/*.ts\" --import \"tests/step-definitions/**/*.ts\" --format progress"
  },
  "dependencies": {
    "mustache": "^4.2.0",
    "yaml": "^2.3.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.1",
    "@types/mustache": "^4.2.0",
    "@types/node": "^20.0.0",
    "puppeteer": "^24.41.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}